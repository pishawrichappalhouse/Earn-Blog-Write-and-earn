rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required, immutable)
    //   - email: string (required)
    //   - displayName: string (required)
    //   - photoURL: string (optional)
    //   - coins: number (required, >= 0)
    //   - totalEarned: number (required, >= 0)
    //   - role: string (required, ['user', 'admin'])
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: posts
    // Document ID: {postId}
    // Fields:
    //   - id: string (required, immutable)
    //   - title: string (required, min 5, max 200)
    //   - content: string (required, min 10)
    //   - authorId: string (required, immutable)
    //   - authorName: string (required)
    //   - category: string (required)
    //   - thumbnail: string (optional)
    //   - views: number (required, >= 0)
    //   - status: string (required, ['pending', 'approved', 'rejected'])
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: withdrawals
    // Document ID: {requestId}
    // Fields:
    //   - id: string (required, immutable)
    //   - userId: string (required, immutable)
    //   - userName: string (required)
    //   - amount: number (required, >= 1000)
    //   - method: string (required, ['JazzCash', 'EasyPaisa', 'Bank'])
    //   - details: string (required)
    //   - status: string (required, ['pending', 'approved', 'cancelled'])
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: settings
    // Document ID: global
    // Fields:
    //   - coinValuePerView: number (required)
    //   - minWithdrawal: number (required)
    //
    // Collection: comments (subcollection of posts)
    // Document ID: {commentId}
    // Fields:
    //   - id: string (required, immutable)
    //   - postId: string (required, immutable)
    //   - userId: string (required, immutable)
    //   - userName: string (required)
    //   - userPhoto: string (optional)
    //   - content: string (required, min 1, max 1000)
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: notifications
    // Document ID: {notificationId}
    // Fields:
    //   - userId: string (required, immutable)
    //   - title: string (required)
    //   - message: string (required)
    //   - type: string (required, ['withdrawal_approved', 'withdrawal_cancelled', 'post_approved', 'post_rejected'])
    //   - read: boolean (required)
    //   - createdAt: timestamp (required, immutable)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "pishawrichappalhouse@gmail.com" ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isValidUser(data) {
      let requiredFields = ['uid', 'email', 'displayName', 'coins', 'totalEarned', 'role', 'createdAt'];
      let optionalFields = ['photoURL', 'membership'];
      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(requiredFields.concat(optionalFields)) &&
             data.uid is string && data.uid.size() > 0 &&
             data.email is string && data.email.size() > 0 &&
             data.displayName is string && data.displayName.size() > 0 &&
             data.coins is number && data.coins >= 0 &&
             data.totalEarned is number && data.totalEarned >= 0 &&
             data.role in ['user', 'admin'] &&
             (data.createdAt is timestamp || data.createdAt == request.time) &&
             (!('membership' in data) || (
               data.membership is map &&
               data.membership.keys().hasAll(['plan', 'status']) &&
               data.membership.plan in ['Free', 'Pro', 'Super Pro', 'Legend Pro'] &&
               data.membership.status in ['none', 'pending', 'approved'] &&
               (!('badge' in data.membership) || data.membership.badge is string) &&
               (!('expiresAt' in data.membership) || (data.membership.expiresAt is timestamp || data.membership.expiresAt == null))
             ));
    }

    function isValidDeposit(data) {
      let requiredFields = ['id', 'userId', 'userName', 'planName', 'amount', 'trxId', 'screenshotUrl', 'status', 'createdAt'];
      return data.keys().hasAll(requiredFields) &&
             data.id is string &&
             data.userId == request.auth.uid &&
             data.userName is string &&
             data.planName in ['Pro', 'Super Pro', 'Legend Pro'] &&
             data.amount is number && data.amount > 0 &&
             data.trxId is string && data.trxId.size() >= 5 &&
             data.screenshotUrl is string &&
             data.status == 'pending' &&
             (data.createdAt is timestamp || data.createdAt == request.time);
    }

    function isValidPost(data) {
      let requiredFields = ['title', 'content', 'authorId', 'authorName', 'category', 'views', 'status', 'createdAt'];
      let optionalFields = ['thumbnail', 'authorBadge', 'authorRole', 'likes', 'likedBy'];
      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(requiredFields.concat(optionalFields)) &&
             data.title is string && data.title.size() >= 5 && data.title.size() <= 200 &&
             data.content is string && data.content.size() >= 4000 && // Approx 800 words
             data.authorId is string && data.authorId == request.auth.uid &&
             data.authorName is string && data.authorName.size() > 0 &&
             data.category is string && data.category.size() > 0 &&
             data.views is number && data.views >= 0 &&
             data.status in ['pending', 'approved', 'rejected'] &&
             (data.createdAt is timestamp || data.createdAt == request.time) &&
             (!('thumbnail' in data) || (data.thumbnail is string)) &&
             (!('authorBadge' in data) || (data.authorBadge is string || data.authorBadge == null)) &&
             (!('authorRole' in data) || (data.authorRole is string)) &&
             (!('likes' in data) || (data.likes is number)) &&
             (!('likedBy' in data) || (data.likedBy is list));
    }

    function isValidWithdrawal(data) {
      return data.keys().hasAll(['userId', 'userName', 'amount', 'method', 'details', 'status', 'createdAt']) &&
             data.userId is string && data.userId == request.auth.uid &&
             data.userName is string && data.userName.size() > 0 &&
             data.amount is number && data.amount >= 1000 &&
             data.method in ['JazzCash', 'EasyPaisa', 'Bank'] &&
             data.details is string && data.details.size() > 0 &&
             data.status in ['pending', 'approved', 'cancelled'] &&
             (data.createdAt is timestamp || data.createdAt == request.time);
    }

    function isValidComment(data) {
      let requiredFields = ['postId', 'userId', 'userName', 'content', 'createdAt'];
      let optionalFields = ['userPhoto', 'userBadge', 'userRole'];
      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(requiredFields.concat(optionalFields)) &&
             data.postId is string && data.postId.size() > 0 &&
             data.userId is string && data.userId == request.auth.uid &&
             data.userName is string && data.userName.size() > 0 &&
             data.content is string && data.content.size() >= 1 && data.content.size() <= 1000 &&
             (data.createdAt is timestamp || data.createdAt == request.time) &&
             (!('userPhoto' in data) || (data.userPhoto is string)) &&
             (!('userBadge' in data) || (data.userBadge is string || data.userBadge == null)) &&
             (!('userRole' in data) || (data.userRole is string));
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'title', 'message', 'type', 'read', 'createdAt']) &&
             data.userId is string && data.userId.size() > 0 &&
             data.title is string && data.title.size() > 0 &&
             data.message is string && data.message.size() > 0 &&
             data.type in ['withdrawal_approved', 'withdrawal_cancelled', 'post_approved', 'post_rejected'] &&
             data.read is bool &&
             (data.createdAt is timestamp || data.createdAt == request.time);
    }

    // Rules for User Collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                    (request.resource.data.role == 'user' || (request.resource.data.role == 'admin' && request.auth.token.email == "pishawrichappalhouse@gmail.com"));
      allow update: if isAuthenticated() && (
        isAdmin() ||
        (isOwner(userId) && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL', 'coins', 'totalEarned', 'membership']) &&
         isValidUser(request.resource.data) &&
         // Prevent self-approval of membership
         (
           !request.resource.data.diff(resource.data).affectedKeys().hasAny(['membership']) ||
           request.resource.data.membership.status == 'pending'
         ))
      );
    }

    // Rules for Posts Collection
    match /posts/{postId} {
      allow read: if true; // Publicly readable
      allow create: if isAuthenticated() && isValidPost(request.resource.data) && 
                    (request.resource.data.status == 'pending' || (request.resource.data.status == 'approved' && isAdmin()));
      allow update: if (isAuthenticated() && (
        (isOwner(resource.data.authorId) && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title', 'content', 'category', 'thumbnail']) &&
         isValidPost(request.resource.data)) ||
        isAdmin() ||
        (
          // Allow liking/unliking
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy']) &&
          (
            // Like: increment by 1, and add current user to likedBy
            (request.resource.data.likes == (resource.data.get('likes', 0) + 1) && 
             request.resource.data.likedBy.size() == (resource.data.get('likedBy', []).size() + 1) &&
             request.resource.data.likedBy.hasAll(resource.data.get('likedBy', [])) &&
             request.auth.uid in request.resource.data.likedBy &&
             !(request.auth.uid in resource.data.get('likedBy', []))) ||
            // Unlike: decrement by 1, and remove current user from likedBy
            (request.resource.data.likes == (resource.data.get('likes', 0) - 1) && 
             request.resource.data.likedBy.size() == (resource.data.get('likedBy', []).size() - 1) &&
             resource.data.get('likedBy', []).hasAll(request.resource.data.likedBy) &&
             !(request.auth.uid in request.resource.data.likedBy) &&
             request.auth.uid in resource.data.get('likedBy', []))
          )
        )
      )) || (
        // Allow public view increment (atomic increment)
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) && 
        request.resource.data.views == resource.data.views + 1
      );
      allow delete: if isAdmin() || isOwner(resource.data.authorId);

      // Rules for Comments Subcollection
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated() && isValidComment(request.resource.data);
        allow update: if false; // Comments are immutable for now
        allow delete: if isAdmin() || isOwner(resource.data.userId);
      }
    }

    // Rules for Withdrawals Collection
    match /withdrawals/{requestId} {
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow create: if isAuthenticated() && isValidWithdrawal(request.resource.data) && request.resource.data.status == 'pending';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Rules for Deposits Collection
    match /deposits/{depositId} {
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow create: if isAuthenticated() && isValidDeposit(request.resource.data) && request.resource.data.status == 'pending';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Rules for Settings Collection
    match /settings/global {
      allow read: if true;
      allow create: if isAuthenticated(); // Allow first user to bootstrap
      allow update: if isAdmin();
    }

    // Rules for Notifications Collection
    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAdmin();
      allow update: if isOwner(resource.data.userId) && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }
  }
}
