{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and earnings information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "coins": { "type": "number", "description": "Current coins balance" },
        "totalEarned": { "type": "number", "description": "Total coins earned ever" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "membership": {
          "type": "object",
          "properties": {
            "plan": { "type": "string", "enum": ["Free", "Pro", "Super Pro", "Legend Pro"] },
            "status": { "type": "string", "enum": ["none", "pending", "approved"] },
            "badge": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "coins", "totalEarned", "role", "createdAt"]
    },
    "Deposit": {
      "title": "Deposit",
      "description": "A deposit request for membership upgrade",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "planName": { "type": "string", "enum": ["Pro", "Super Pro", "Legend Pro"] },
        "amount": { "type": "number" },
        "trxId": { "type": "string", "description": "Transaction ID" },
        "screenshotUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "userName", "planName", "amount", "trxId", "screenshotUrl", "status", "createdAt"]
    },
    "BlogPost": {
      "title": "Blog Post",
      "description": "A blog post created by a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "category": { "type": "string" },
        "thumbnail": { "type": "string" },
        "views": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "content", "authorId", "authorName", "category", "views", "status", "createdAt"]
    },
    "WithdrawalRequest": {
      "title": "Withdrawal Request",
      "description": "A request to withdraw coins for cash",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "amount": { "type": "number", "description": "Amount in coins" },
        "method": { "type": "string", "enum": ["JazzCash", "EasyPaisa", "Bank"] },
        "details": { "type": "string", "description": "Account number or bank details" },
        "status": { "type": "string", "enum": ["pending", "approved", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "userName", "amount", "method", "details", "status", "createdAt"]
    },
    "PlatformSettings": {
      "title": "Platform Settings",
      "description": "Global settings for the platform",
      "type": "object",
      "properties": {
        "coinValuePerView": { "type": "number", "description": "How many coins earned per view" },
        "minWithdrawal": { "type": "number", "description": "Minimum coins required for withdrawal" }
      },
      "required": ["coinValuePerView", "minWithdrawal"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a blog post",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "postId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "postId", "userId", "userName", "content", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification for a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["withdrawal_approved", "withdrawal_cancelled", "post_approved", "post_rejected"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "message", "type", "read", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/posts/{postId}": { "schema": "BlogPost", "description": "Blog posts" },
    "/posts/{postId}/comments/{commentId}": { "schema": "Comment", "description": "Comments on a blog post" },
    "/withdrawals/{requestId}": { "schema": "WithdrawalRequest", "description": "Withdrawal requests" },
    "/deposits/{depositId}": { "schema": "Deposit", "description": "Membership deposit requests" },
    "/settings/global": { "schema": "PlatformSettings", "description": "Global platform settings" },
    "/notifications/{notificationId}": { "schema": "Notification", "description": "User notifications" }
  }
}
